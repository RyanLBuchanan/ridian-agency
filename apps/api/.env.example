# Ridian Agency — example environment file.
#
# Copy this file to apps/api/.env and fill in values, OR leave it blank and
# enter values through the desktop Settings panel after launching the app.
# Settings entered through the GUI are saved to apps/api/local_settings.json
# (git-ignored) and take precedence over .env.
#
# Both .env and local_settings.json are git-ignored — neither will ever be
# committed.

# ------------------------------------------------------------------------
# Anthropic — required to run any workflow.
# Get a key at https://console.anthropic.com/settings/keys
# ------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI — OPTIONAL. Only used for microphone voice input (Whisper).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------------------
# SMTP — optional. Only needed for the "Approve & Send Email to Me" button
# in the desktop app. If unset, /email/send-approved returns a clear
# "SMTP not configured" error and the workflow itself still works.
#
# Gmail tip: turn on 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords and paste it into SMTP_PASSWORD.
# Your normal Google password will NOT work.
#
# Common providers:
#   smtp.gmail.com         port 587 (STARTTLS, recommended)
#   smtp.office365.com     port 587 (STARTTLS)
#   smtp.fastmail.com      port 465 (implicit TLS)
# ------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
DEFAULT_TO_EMAIL=

# ------------------------------------------------------------------------
# Optional: override where workflow artifacts are written.
# Defaults to <repo>/outputs.
# ------------------------------------------------------------------------
OUTPUTS_DIR=

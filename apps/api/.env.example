# Copy to .env and fill in. .env is git-ignored.

# Required: your OpenAI API key.
OPENAI_API_KEY=sk-replace-me

# Optional: model used by every agent. Defaults to gpt-4o-mini.
# Examples: gpt-4o-mini, gpt-4o, gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini

# Optional: override the artifact output directory.
# Defaults to <repo>/outputs.
# OUTPUTS_DIR=C:\path\to\your\outputs

# ------------------------------------------------------------------------
# Optional: SMTP for the "Approve & Send Email to Me" button in the GUI.
# If unset, the /email/send-approved endpoint returns a clear
# "SMTP not configured" error (the workflow still produces draft_email.md).
#
# Gmail tip: turn on 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords and paste it into SMTP_PASSWORD.
# Your normal Google password will NOT work.
#
# Examples:
#   SMTP_HOST=smtp.gmail.com           SMTP_PORT=587   (STARTTLS — recommended)
#   SMTP_HOST=smtp.office365.com       SMTP_PORT=587   (STARTTLS)
#   SMTP_HOST=smtp.fastmail.com        SMTP_PORT=465   (implicit TLS)
# ------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
DEFAULT_TO_EMAIL=
